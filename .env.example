# Odysseus UI — Environment Configuration
# Copy this file to .env and fill in your values.

# ============================================================
# LLM Configuration
# ============================================================

# Primary LLM host — OpenAI-compatible base URL.
# nano-gpt.com is the recommended provider (supports 600+ models, OpenAI-compatible).
# Get an API key at https://nano-gpt.com
LLM_HOST=https://nano-gpt.com/api/v1

# For a local Ollama instance instead:
# LLM_HOST=http://localhost:11434/v1

# Additional LLM hosts for model discovery, comma-separated.
# LLM_HOSTS=other-host.local:8000,backup.local:8001

# API key for your LLM provider (passed as Authorization: Bearer).
# Required for nano-gpt, OpenAI, and most hosted providers.
# Do not commit real keys.
# OPENAI_API_KEY=your_api_key_here

# Default model ID for new sessions (must be available at LLM_HOST).
# nano-gpt examples:
#   deepseek/deepseek-v3.2            - strong general-purpose, low cost
#   anthropic/claude-sonnet-4.6       - best quality
#   openai/gpt-4.1                    - GPT-4 class
#   google/gemini-3-flash-preview     - fast and cheap
#   deepseek/deepseek-v4-pro          - high reasoning
#   x-ai/grok-4-07-09                 - Grok 4
#   moonshotai/kimi-k2.5              - strong alternative
# DEFAULT_MODEL=deepseek/deepseek-v3.2

# Research feature LLM endpoint (explicit chat/completions URL).
# RESEARCH_LLM_ENDPOINT=https://nano-gpt.com/api/v1/chat/completions

# ============================================================
# Search & Web
# ============================================================

# SearXNG instance URL.
# Docker Compose overrides this to http://searxng:8080 for in-network access.
SEARXNG_INSTANCE=http://localhost:8080

# ============================================================
# Database
# ============================================================

# SQLite database path (default: sqlite:///./data/app.db)
# DATABASE_URL=sqlite:///./data/app.db

# ============================================================
# Auth & Security
# ============================================================

# Enable authentication (default: true)
# AUTH_ENABLED=true

# Development-only auth bypass for loopback requests.
# Keep false for Docker, LAN, reverse proxy, and any shared deployment.
# LOCALHOST_BYPASS=false

# Optional: pre-seed the first admin password on first boot.
# Has no effect once the account exists. Do not commit a real password.
# ODYSSEUS_ADMIN_PASSWORD=change_me_before_first_boot

# CORS allowed origins — restrict to your public domain in production.
# ALLOWED_ORIGINS=https://your-domain.example.com

# ============================================================
# ChromaDB (vector store)
# ============================================================

# ChromaDB service host.
# Manual host run: localhost:8100 when using `docker run -p 8100:8000 chromadb/chroma`.
# Docker Compose overrides these to chromadb:8000 for in-network access.
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8100

# ============================================================
# RAG / Embeddings
# ============================================================

# Embedding API endpoint (OpenAI-compatible /v1/embeddings).
# nano-gpt: https://nano-gpt.com/api/v1/embeddings
# Ollama:   http://localhost:11434/v1/embeddings
# EMBEDDING_URL=https://nano-gpt.com/api/v1/embeddings

# Embedding model name (must be available at EMBEDDING_URL).
# nano-gpt: BAAI/bge-m3 (strong multilingual embedder)
# Ollama:   all-minilm:l6-v2
# EMBEDDING_MODEL=BAAI/bge-m3

# Local fallback embedding model (used when EMBEDDING_URL is unreachable).
# Uses fastembed (ONNX) — downloads model on first run (~50MB).
# FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# FASTEMBED_CACHE_PATH=  # defaults to ~/.cache/fastembed

# ============================================================
# Misc
# ============================================================

# Cleanup interval in hours (default: 24)
# CLEANUP_INTERVAL_HOURS=24

# In-process email pollers (default: on). Set to 0 if you're driving
# polling from cron / systemd via `scripts/odysseus-mail poll-scheduled`
# and `scripts/odysseus-mail poll-summary`, otherwise both schedulers
# race on the same SQLite.
# ODYSSEUS_INPROCESS_POLLERS=1

# In-process scheduled-task runner (default: on). Set to 0 to let an
# external driver fire scheduled tasks. Calendar reminders are
# frontend-driven (polling /api/notes from the browser) so no gate is
# needed there.
# ODYSSEUS_INPROCESS_TASKS=1

# Host used by the built-in "run_script" scheduled-task action.
# Empty/local/localhost runs scripts on the app host. Set to an SSH host alias
# if you intentionally want scheduled scripts to run remotely.
# ODYSSEUS_SCRIPT_HOST=localhost
